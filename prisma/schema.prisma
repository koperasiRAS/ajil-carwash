// CarWash POS — Simplified Schema
// For single-admin operation: no shifts, no stock, no audit logs.

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum TransactionStatus {
  COMPLETED
  VOIDED
}

enum PaymentMethod {
  CASH
  TRANSFER
  QRIS
}

enum VehicleType {
  MOTOR
  MOBIL
  PICKUP
  TRUK
}

// ── User (Admin) ───────────────────────────────────────────────────────────────
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  pin       String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]
  voidedTx      Transaction[] @relation("VoidedBy")
}

// ── Transaction ────────────────────────────────────────────────────────────────
model Transaction {
  id              String            @id @default(uuid())
  invoiceNumber   String            @unique
  kasirId         String
  platNomor       String           @default("")
  customerName    String?
  vehicleType     VehicleType
  paymentMethod   PaymentMethod
  subtotal        Int
  discount        Int               @default(0)
  total           Int
  paymentAmount   Int
  change          Int               @default(0)
  status          TransactionStatus @default(COMPLETED)
  voidReason      String?
  voidById        String?
  voidAt          DateTime?
  createdAt       DateTime          @default(now())

  kasir   User              @relation(fields: [kasirId], references: [id])
  voidBy  User?             @relation("VoidedBy", fields: [voidById], references: [id])
  items   TransactionItem[]
}

// ── TransactionItem ───────────────────────────────────────────────────────────
model TransactionItem {
  id            String @id @default(uuid())
  transactionId String
  serviceName   String
  price         Int
  quantity      Int    @default(1)
  subtotal      Int

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}
